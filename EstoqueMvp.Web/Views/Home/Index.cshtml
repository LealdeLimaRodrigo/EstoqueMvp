@{
    ViewBag.Title = "Dashboard - Controle de Estoque";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-4">
    <h2><i class="fas fa-chart-pie"></i> Visão Geral</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md">
        <div class="card text-white rounded-4 shadow-sm h-100 card-clickable" role="button" tabindex="0" aria-label="Ver todos os produtos" data-href="/Produto/Index" style="background-color:#4F46E5;">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-cubes me-1"></i>Produtos</h6>
                <h2 id="cardTotalProdutos" class="display-6"><span class="placeholder-wave"><span class="placeholder col-4"></span></span></h2>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-white bg-warning rounded-4 shadow-sm h-100 card-clickable" role="button" tabindex="0" aria-label="Ver produtos com estoque baixo" id="cardEstoqueBaixoLink" data-href="/Produto/Index?filtro=estoque-baixo">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-exclamation-triangle me-1"></i>Estoque Baixo</h6>
                <h2 id="cardEstoqueBaixo" class="display-6"><span class="placeholder-wave"><span class="placeholder col-4"></span></span></h2>
                <small>Menos de 10 unid.</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-white bg-success rounded-4 shadow-sm h-100 card-clickable" role="button" tabindex="0" aria-label="Ver movimentações de entrada" data-href="/Movimentacao/Index?tipo=ENTRADA">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-arrow-down me-1"></i>Entradas</h6>
                <h2 id="cardEntradasMes" class="display-6"><span class="placeholder-wave"><span class="placeholder col-4"></span></span></h2>
                <small>Este mês</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md">
        <div class="card text-white bg-danger rounded-4 shadow-sm h-100 card-clickable" role="button" tabindex="0" aria-label="Ver consumos" data-href="/Movimentacao/Index?tipo=CONSUMO">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-arrow-up me-1"></i>Consumos</h6>
                <h2 id="cardConsumosMes" class="display-6"><span class="placeholder-wave"><span class="placeholder col-4"></span></span></h2>
                <small>Este mês</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-md">
        <div class="card text-white bg-primary rounded-4 shadow-sm h-100 card-clickable" role="button" tabindex="0" aria-label="Ver transferências" data-href="/Movimentacao/Index?tipo=TRANSFERENCIA">
            <div class="card-body">
                <h6 class="card-title"><i class="fas fa-exchange-alt me-1"></i>Transferências</h6>
                <h2 id="cardTransferenciasMes" class="display-6"><span class="placeholder-wave"><span class="placeholder col-4"></span></span></h2>
                <small>Este mês</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card rounded-4 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Operações dos Últimos 7 Dias</h5>
            </div>
            <div class="card-body" style="height: 300px;">
                <canvas id="graficoMovimentacao"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card rounded-4 shadow-sm h-100">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Ações Rápidas</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center gap-3">
                <a href="/Produto/Index" class="btn btn-outline-primary"><i class="fas fa-plus"></i> Novo Produto</a>
                <a href="/Movimentacao/Index" class="btn btn-outline-success"><i class="fas fa-arrow-down"></i> Gerenciar Estoque</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-4">
    <div class="col-12">
        <div class="card rounded-4 shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-history me-1"></i>Últimas 5 Movimentações</h5>
                <a href="/Movimentacao/Index" class="btn btn-sm btn-outline-light">Ver todas</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0" id="tabelaUltimasMov">
                        <thead class="table-light">
                            <tr>
                                <th>Data</th>
                                <th>Tipo</th>
                                <th>Produto</th>
                                <th>Qtd</th>
                                <th>Setor</th>
                            </tr>
                        </thead>
                        <tbody aria-live="polite">
                            <tr><td colspan="5" class="text-center text-muted py-3">Carregando...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js" integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ" crossorigin="anonymous"></script>
    <script>window.Chart || document.write('<script src="/Scripts/lib/chart.min.js"><\/script>')</script>
    @System.Web.Optimization.Scripts.Render("~/bundles/home-index")
}