@{
    ViewBag.Title = "Erro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm">
            <div class="card-body py-5">
                <i class="fas fa-exclamation-triangle fa-4x text-warning mb-4 d-block"></i>
                <h2 class="mb-3">Ops! Algo deu errado</h2>
                <p class="text-muted mb-4">
                    Ocorreu um erro inesperado ao processar sua solicitação.<br>
                    Tente novamente ou volte para a página inicial.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/Home/Index" class="btn btn-primary">
                        <i class="fas fa-home me-1"></i> Página Inicial
                    </a>
                    <button class="btn btn-outline-secondary" onclick="history.back()">
                        <i class="fas fa-arrow-left me-1"></i> Voltar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
