@{
    ViewBag.Title = "Gestão de Setores";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-4">
    <h2><i class="fas fa-building"></i> Gestão de Setores</h2>
    <button class="btn btn-success" id="btnNovoSetor">
        <i class="fas fa-plus"></i> Novo Setor
    </button>
</div>

<div class="card rounded-4 shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
            <div class="input-group search-box">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" id="buscaSetor" class="form-control" placeholder="Buscar por nome..." aria-label="Buscar setores">
            </div>
            <small id="totalSetoresInfo" class="text-muted"></small>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle" id="tabelaSetores">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody aria-live="polite">
                </tbody>
            </table>
        </div>
        <div id="paginacaoSetores" class="mt-2"></div>
    </div>
</div>

<!-- Modal Criar/Editar Setor -->
<div class="modal fade" id="modalSetor" tabindex="-1" aria-labelledby="tituloModalSetor" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header navbar-indigo text-white">
                <h5 class="modal-title" id="tituloModalSetor"><i class="fas fa-building"></i> Novo Setor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formSetor">
                    <div class="mb-3">
                        <label for="setNome" class="form-label">Nome do Setor *</label>
                        <input type="text" id="setNome" class="form-control" placeholder="Ex: Almoxarifado" required aria-describedby="setNomeFeedback">
                        <div class="invalid-feedback" id="setNomeFeedback">Informe o nome do setor.</div>
                    </div>
                    <div class="alert alert-danger d-none" id="modalSetorErro" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnSalvarSetor">Confirmar Cadastro</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @System.Web.Optimization.Scripts.Render("~/bundles/setor")
}
