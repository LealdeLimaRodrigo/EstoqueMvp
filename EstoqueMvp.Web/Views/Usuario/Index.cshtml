@{
    ViewBag.Title = "Gestão de Usuários";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-4">
    <h2><i class="fas fa-users"></i> Gestão de Usuários</h2>
    <button class="btn btn-success" id="btnNovoUsuario">
        <i class="fas fa-user-plus"></i> Novo Usuário
    </button>
</div>

<div class="card rounded-4 shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
            <div class="input-group search-box">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" id="buscaUsuario" class="form-control" placeholder="Buscar por nome, CPF..." aria-label="Buscar usuários">
            </div>
            <small id="totalUsuariosInfo" class="text-muted"></small>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle" id="tabelaUsuarios">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody aria-live="polite">
                </tbody>
            </table>
        </div>
        <div id="paginacaoUsuarios" class="mt-2"></div>
    </div>
</div>

<!-- Modal Criar/Editar Usuário -->
<div class="modal fade" id="modalUsuario" tabindex="-1" aria-labelledby="tituloModalUsuario" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header navbar-indigo text-white">
                <h5 class="modal-title" id="tituloModalUsuario"><i class="fas fa-user-plus"></i> Novo Usuário</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formUsuario">
                    <div class="mb-3">
                        <label for="usuNome" class="form-label">Nome Completo *</label>
                        <input type="text" id="usuNome" class="form-control" placeholder="Ex: João da Silva" required aria-describedby="usuNomeFeedback">
                        <div class="invalid-feedback" id="usuNomeFeedback">Informe o nome do usuário.</div>
                    </div>
                    <div class="mb-3">
                        <label for="usuCpf" class="form-label">CPF *</label>
                        <input type="text" id="usuCpf" class="form-control" placeholder="000.000.000-00" maxlength="14" required aria-describedby="cpfFeedback" autocomplete="off">
                        <div class="invalid-feedback" id="cpfFeedback">Informe um CPF válido.</div>
                    </div>
                    <div class="mb-3">
                        <label for="usuSenha" class="form-label">Senha *</label>
                        <input type="password" id="usuSenha" class="form-control" placeholder="Mínimo 6 caracteres" required aria-describedby="usuSenhaFeedback senhaHint" autocomplete="new-password">
                        <div class="invalid-feedback" id="usuSenhaFeedback">Informe uma senha com no mínimo 6 caracteres.</div>
                        <small id="senhaHint" class="form-text text-muted d-none">Deixe em branco para manter a senha atual.</small>
                    </div>
                    <div class="alert alert-danger d-none" id="modalUsuarioErro" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnSalvarUsuario">Confirmar Cadastro</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @System.Web.Optimization.Scripts.Render("~/bundles/usuario")
}
