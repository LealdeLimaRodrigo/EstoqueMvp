<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Controle de Estoque</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📦</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha384-3B6NwesSXE7YJlcLI9RpRqGf2p/EgVH8BgoKTaUrmKNDkHPStTQ3EyoYjCGXaOTS" crossorigin="anonymous"
          onerror="this.onerror=null;this.href='/Content/lib/font-awesome-all.min.css';">
    @System.Web.Optimization.Styles.Render("~/bundles/css")
</head>
<body class="bg-body-tertiary">
    <!-- Skip Navigation (a11y) -->
    <a href="#mainContent" class="skip-link visually-hidden-focusable position-absolute top-0 start-0 bg-primary text-white px-3 py-2 z-3">Ir para conteúdo principal</a>

    @if (ViewBag.HideNavbar != true)
    {
    <!-- Top bar slim (sticky) -->
    <nav class="navbar navbar-dark navbar-indigo py-2 sticky-top" style="z-index: 1050;">
        <div class="container-fluid px-3">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-link text-white d-lg-none p-0 me-1" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-label="Abrir menu">
                    <i class="fas fa-bars fa-lg"></i>
                </button>
                <a class="navbar-brand mb-0" href="@Url.Action("Index", "Home")"><i class="fas fa-boxes me-1"></i>Estoque MVP</a>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button id="btnTema" class="btn-theme-toggle" title="Alternar tema" aria-label="Alternar tema claro/escuro"><i class="fas fa-moon"></i></button>
                <span id="saudacaoUsuario" class="text-light small d-none"><i class="fas fa-user-circle me-1"></i><span id="nomeUsuario"></span></span>
                <button id="btnSair" class="btn btn-outline-light btn-sm d-none" aria-label="Sair do sistema"><i class="fas fa-sign-out-alt me-1"></i>Sair</button>
            </div>
        </div>
    </nav>

    <!-- Sidebar offcanvas (mobile) + fixed (desktop) -->
    <div class="offcanvas-lg offcanvas-start sidebar-indigo" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel">
        <div class="offcanvas-header navbar-indigo text-white">
            <h5 class="offcanvas-title" id="sidebarMenuLabel"><i class="fas fa-boxes me-1"></i>Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu" aria-label="Fechar menu"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column p-0">
            <nav class="nav flex-column sidebar-nav flex-grow-1">
                <a class="nav-link" href="@Url.Action("Index", "Home")"><i class="fas fa-chart-line fa-fw me-2"></i>Dashboard</a>
                <a class="nav-link" href="@Url.Action("Index", "Produto")"><i class="fas fa-box fa-fw me-2"></i>Produtos</a>
                <a class="nav-link" href="@Url.Action("Index", "Movimentacao")"><i class="fas fa-exchange-alt fa-fw me-2"></i>Movimentações</a>
                <a class="nav-link" href="@Url.Action("Index", "Setor")"><i class="fas fa-building fa-fw me-2"></i>Setores</a>
                <a class="nav-link" href="@Url.Action("Index", "Usuario")"><i class="fas fa-users fa-fw me-2"></i>Usuários</a>
            </nav>
        </div>
    </div>
    }

    <div class="@(ViewBag.HideNavbar == true ? "" : "content-with-sidebar") d-flex flex-column" style="min-height: @(ViewBag.HideNavbar == true ? "100vh" : "calc(100vh - 52px)");">

        <main id="mainContent" class="container py-4 flex-grow-1 d-flex flex-column">
            <!-- Breadcrumbs -->
            @if (ViewBag.Breadcrumbs != null)
            {
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb bg-body-secondary rounded-3 px-3 py-2 mb-0 small">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fas fa-home me-1"></i>Início</a></li>
                        @foreach (var crumb in (IEnumerable<Tuple<string, string>>)ViewBag.Breadcrumbs)
                        {
                            if (crumb.Item2 != null)
                            {
                                <li class="breadcrumb-item"><a href="@crumb.Item2" class="text-decoration-none">@crumb.Item1</a></li>
                            }
                            else
                            {
                                <li class="breadcrumb-item active fw-semibold" aria-current="page">@crumb.Item1</li>
                            }
                        }
                    </ol>
                </nav>
            }
            @RenderBody()
        </main>

        <footer class="py-3 border-top text-body-secondary small text-center mt-auto">
            <div class="container">
                <span>&copy; @DateTime.Now.Year — Sistema de Gestão de Estoque (MVP)</span>
            </div>
        </footer>
    </div>

    <!-- Toast Container (a11y: role=status para screen readers) -->
    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090" role="status" aria-live="polite"></div>

    <!-- 3.3 — Modal de Confirmação Global -->
    <div class="modal fade" id="modalConfirmacao" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="confirmModalTitle">Confirmar</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body" id="confirmModalBody">Tem certeza?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary d-none" id="btnConfirmNao">Não, criar novo</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmSim">Sim, confirmar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 3.4 — Modal de Detalhes Global -->
    <div class="modal fade" id="modalDetalhes" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header navbar-indigo text-white">
                    <h5 class="modal-title" id="detalhesModalTitle"><i class="fas fa-eye me-1"></i> Detalhes</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body" id="detalhesModalBody"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script>window.bootstrap || document.write('<script src="/Scripts/lib/bootstrap.bundle.min.js"><\/script>')</script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js" integrity="sha384-hmTjheSx+Ma2rUsS28gIvcS5PL+YagfURozh9RBnC1eenF5bKVWNrDV+Ix8q2zGv" crossorigin="anonymous"></script>
    <script>window.axios || document.write('<script src="/Scripts/lib/axios.min.js"><\/script>')</script>

    <script>var API_URL = '@System.Configuration.ConfigurationManager.AppSettings["ApiBaseUrl"]' || 'https://localhost:44333/api';</script>
    @System.Web.Optimization.Scripts.Render("~/bundles/app")

    @RenderSection("scripts", required: false)
</body>
</html>
