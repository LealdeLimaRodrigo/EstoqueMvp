
@{
    ViewBag.Title = "Cadastro de Produtos";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-4">
    <h2><i class="fas fa-box"></i> Gestão de Produtos</h2>
    <button class="btn btn-success" id="btnNovoProduto" data-bs-toggle="modal" data-bs-target="#modalNovoProduto">
        <i class="fas fa-plus"></i> Novo Produto
    </button>
</div>

<div class="card rounded-4 shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
            <div class="input-group search-box">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" id="buscaProduto" class="form-control" placeholder="Buscar por nome, SKU..." aria-label="Buscar produtos">
            </div>
            <small id="totalProdutosInfo" class="text-muted"></small>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle" id="tabelaProdutos">
                <thead class="table-light">
                    <tr>
                        <th>SKU</th>
                        <th>Nome</th>
                        <th>Preço</th>
                        <th>Estoque</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody aria-live="polite">
                </tbody>
            </table>
        </div>
        <div id="paginacaoProdutos" class="mt-2"></div>
    </div>
</div>

<div class="modal fade" id="modalNovoProduto" tabindex="-1" aria-labelledby="tituloModalProduto" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header navbar-indigo text-white">
                <h5 class="modal-title" id="tituloModalProduto"><i class="fas fa-box-open"></i> Novo Produto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formProduto">
                    <div class="mb-3">
                        <label for="prodNome" class="form-label">Nome do Produto *</label>
                        <input type="text" id="prodNome" class="form-control" placeholder="Ex: Monitor Gamer 24'" required aria-describedby="prodNomeFeedback">
                        <div class="invalid-feedback" id="prodNomeFeedback">Informe o nome do produto.</div>
                    </div>
                    <div class="mb-3">
                        <label for="prodDescricao" class="form-label">Descrição</label>
                        <textarea id="prodDescricao" class="form-control" rows="2" placeholder="Detalhes técnicos..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="prodPreco" class="form-label">Preço (R$) *</label>
                        <input type="number" id="prodPreco" class="form-control" step="0.01" min="0" required aria-describedby="prodPrecoFeedback">
                        <div class="invalid-feedback" id="prodPrecoFeedback">Informe o preço.</div>
                    </div>
                    <div class="alert alert-danger d-none" id="modalErro" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnSalvarProduto">Confirmar Cadastro</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @System.Web.Optimization.Scripts.Render("~/bundles/produto")
}